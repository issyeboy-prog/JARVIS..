# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — your keys never get committed.

# ElevenLabs (https://elevenlabs.io) — for JARVIS's speaking voice.
# Get an API key from your ElevenLabs account settings.
ELEVENLABS_API_KEY=
# Pick a voice ID from https://elevenlabs.io/app/voice-library (or your own cloned voice).
# Defaults to "Adam" (a stock deep male voice) if left blank.
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB
