# Copy this file to .env.local and fill in your own values.
# .env.local is gitignored — your keys never get committed.

# ElevenLabs (https://elevenlabs.io) — for JARVIS's speaking voice.
# Get an API key from your ElevenLabs account settings.
ELEVENLABS_API_KEY=
# Pick a voice ID from https://elevenlabs.io/app/voice-library (or your own cloned voice).
# Defaults to "Adam" (a stock deep male voice) if left blank.
ELEVENLABS_VOICE_ID=pNInz6obpgDQGcFmaJgB

# Anthropic (https://console.anthropic.com) — JARVIS's actual "brain".
# Without this, voice commands still work but just echo back canned replies.
ANTHROPIC_API_KEY=
# Optional — defaults to a fast/cheap model, good for a real-time voice loop.
ASSISTANT_MODEL=claude-haiku-4-5-20251001
